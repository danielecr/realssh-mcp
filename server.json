{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.danielecr/realssh-mcp",
  "description": "MCP server for SSH remote command execution",
  "repository": {
    "url": "https://github.com/danielecr/realssh-mcp",
    "source": "github"
  },
  "version": "1.0.6",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@danielecr/realssh-mcp",
      "version": "1.0.6",
      "transport": {
        "type": "stdio"
      },
      "configSchema": {
        "type": "object",
        "properties": {
          "SSH_HOST": {
            "type": "string",
            "description": "The remote SSH host address"
          }
        },
        "required": []
      }
    }
  ]
}