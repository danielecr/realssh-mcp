{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.danielecr/realssh-mcp",
  "description": "MCP server for SSH remote command execution",
  "repository": {
    "url": "https://github.com/danielecr/realssh-mcp",
    "source": "github"
  },
  "version": "1.0.6",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@danielecr/realssh-mcp",
      "version": "1.0.6",
      "transport": {
        "type": "stdio"
      },
      "installs": {
        "npm": {
          "command": "npx",
          "args": ["-y", "@danielecr/realssh-mcp"]
        }
      },
      "configSchema": {
        "type": "object",
        "properties": {},
        "description": "This server uses dynamic tool arguments for SSH connections and does not require persistent environment configuration."
      }
    }
  ]
}